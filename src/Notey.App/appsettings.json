{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "OpenTelemetry": {
      "Endpoint": ""
    }
  },
  "Notey": {
    "Ui": {
      "Theme": "Dark",
      "DefaultWindowWidth": 1180,
      "DefaultWindowHeight": 760
    },
    "Hotkeys": {
      "OpenNote": "Ctrl+Alt+N"
    },
    "Vault": {
      "RootPath": ""
    },
    "Ai": {
      "DefaultProviderId": "default",
      "BaseUrl": "",
      "ApiKey": "",
      "ApiKeyEnvironmentVariable": "NOTEY_AI_API_KEY",
      "ModelName": "",
      "RequestTimeoutSeconds": 60,
      "StoreApiKeyInPlaintext": false,
      "PersonConfidenceThreshold": 0.85,
      "TagConfidenceThreshold": 0.75,
      "Providers": []
    },
    "Ocr": {
      "TesseractDataPath": "",
      "DefaultLanguage": "eng"
    }
  }
}
