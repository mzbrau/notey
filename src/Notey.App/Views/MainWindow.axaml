<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        x:Class="Notey.App.Views.MainWindow"
        Title="Notey"
        Icon="/Assets/notey.png"
        Width="1180"
        Height="760"
        MinWidth="840"
        MinHeight="520">
  <Grid RowDefinitions="52,Auto,*,Auto,Auto,34"
        Background="{DynamicResource Notey.SurfaceBrush}">
    <Border Grid.Row="0"
            BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource Notey.SurfaceBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="22,0">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
          <Image Source="avares://Notey/Assets/notey.png"
                 Width="50"
                 Height="50"
                 Stretch="Uniform"
                 AutomationProperties.Name="Notey icon" />
          <TextBlock Classes="appTitle"
                     Text="Notey"
                     VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="6">
          <Button x:Name="NewNoteButton" Classes="command" ToolTip.Tip="Process current draft and start new note" AutomationProperties.Name="New note">
            <PathIcon Classes="commandIcon" Data="M6,4 L14,4 L18,8 L18,20 L6,20 Z M13,4 L13,9 L18,9 M12,12 L12,17 M9.5,14.5 L14.5,14.5" />
          </Button>
          <Button x:Name="OpenRecentNoteButton" Classes="command" ToolTip.Tip="Open recent note" AutomationProperties.Name="Open recent final note">
            <PathIcon Classes="commandIcon" Data="M4,6 L9,6 L11,8 L20,8 L20,18 L4,18 Z M8,11 L16,11 M8,14 L14,14" />
          </Button>
          <Rectangle Width="1" Height="22" Fill="{DynamicResource Notey.OutlineVariantBrush}" Margin="6,0" />
          <Button x:Name="CaptureAnalyzeButton" Classes="command" ToolTip.Tip="OCR temporary screenshot and discard image" AutomationProperties.Name="OCR temporary screenshot">
            <PathIcon Classes="commandIcon" Data="M4,7 L8,7 L10,5 L14,5 L16,7 L20,7 L20,18 L4,18 Z M12,9 A3,3 0,1 0,12,15 A3,3 0,1 0,12,9 M17,10 L18,12 L17,14 L16,12 Z" />
          </Button>
          <Button x:Name="CaptureSaveButton" Classes="command" ToolTip.Tip="Capture persistent image" AutomationProperties.Name="Capture persistent image">
            <PathIcon Classes="commandIcon" Data="M4,7 L8,7 L10,5 L14,5 L16,7 L20,7 L20,18 L4,18 Z M12,9 A3,3 0,1 0,12,15 A3,3 0,1 0,12,9 M12,12 L12,17 M9,14 L12,17 L15,14" />
          </Button>
          <Rectangle Width="1" Height="22" Fill="{DynamicResource Notey.OutlineVariantBrush}" Margin="6,0" />
          <Button x:Name="SaveNoteButton" Classes="command" ToolTip.Tip="Save draft" AutomationProperties.Name="Save draft">
            <PathIcon Classes="commandIcon" Data="M5,12 L10,17 L19,7" />
          </Button>
          <Button x:Name="ImportButton" Classes="command" ToolTip.Tip="Import existing documents" AutomationProperties.Name="Import existing documents">
            <PathIcon Classes="commandIcon" Data="M5,5 L19,5 L19,9 L17,9 L17,7 L7,7 L7,17 L17,17 L17,15 L19,15 L19,19 L5,19 Z M12,9 L16,13 L13.5,13 L13.5,16 L10.5,16 L10.5,13 L8,13 Z" />
          </Button>
          <Button x:Name="TasksButton" Classes="command" ToolTip.Tip="Show tasks" AutomationProperties.Name="Show tasks">
            <Grid>
              <PathIcon Classes="commandIcon" Data="M7,4 L17,4 L17,20 L7,20 Z M9,8 L11,10 L15,6 M9,13 L11,15 L15,11" />
              <Border x:Name="TasksBadge"
                      Background="#D64D4D"
                      CornerRadius="8"
                      MinWidth="16"
                      Height="16"
                      Padding="4,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,-9,-9,0"
                      IsVisible="False">
                <TextBlock x:Name="TasksBadgeText"
                           Text="0"
                           Foreground="White"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
            </Grid>
          </Button>
          <Button x:Name="AssistantButton" Classes="command" ToolTip.Tip="Show Notey Assistant" AutomationProperties.Name="Show Notey Assistant">
            <PathIcon Classes="commandIcon" Data="M5,5 L19,5 C20.1,5 21,5.9 21,7 L21,15 C21,16.1 20.1,17 19,17 L10,17 L6,21 L6,17 L5,17 C3.9,17 3,16.1 3,15 L3,7 C3,5.9 3.9,5 5,5 Z M8,9 L16,9 M8,12 L13,12 M17,10 L18,12 L17,14 L16,12 Z" />
          </Button>
          <Button x:Name="SettingsButton" Classes="command" ToolTip.Tip="Open settings" AutomationProperties.Name="Open settings">
            <PathIcon Classes="commandIcon" Data="M12,8 A4,4 0,1 0,12,16 A4,4 0,1 0,12,8 M12,3 L13,5.2 L15.4,5.7 L17,4.2 L19.8,7 L18.3,8.6 L18.8,11 L21,12 L18.8,13 L18.3,15.4 L19.8,17 L17,19.8 L15.4,18.3 L13,18.8 L12,21 L11,18.8 L8.6,18.3 L7,19.8 L4.2,17 L5.7,15.4 L5.2,13 L3,12 L5.2,11 L5.7,8.6 L4.2,7 L7,4.2 L8.6,5.7 L11,5.2 Z" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource Notey.SurfaceLowBrush}"
            Padding="28,10">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*"
            ColumnSpacing="12"
            VerticalAlignment="Center">
        <TextBlock Grid.Column="0" Classes="label" Text="DRAFT" VerticalAlignment="Center" />
        <Border Grid.Column="1" Classes="metadata-chip">
          <TextBlock x:Name="DateChipText" Classes="chipText" Text="No draft" />
        </Border>
        <TextBlock Grid.Column="2" Classes="label" Text="CONTEXT" VerticalAlignment="Center" Margin="10,0,0,0" />
        <Border Grid.Column="3" Classes="metadata-chip" HorizontalAlignment="Left">
          <TextBlock x:Name="ContextChipText" Classes="chipText" Text="/ for commands, @ for people" />
        </Border>
      </Grid>
    </Border>

    <Grid x:Name="WorkspaceGrid"
          Grid.Row="2"
          ColumnDefinitions="*,6,Auto">
      <Grid Grid.Column="0">
        <Border BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource Notey.SurfaceBrush}">
          <ae:TextEditor x:Name="NoteEditor"
                         Classes="noteEditor"
                         FontFamily="Cascadia Mono, JetBrains Mono, Menlo, Consolas, Courier New, monospace"
                         ShowLineNumbers="True"
                         IsReadOnly="True"
                         WordWrap="True"
                         HorizontalScrollBarVisibility="Disabled"
                         VerticalScrollBarVisibility="Auto" />
        </Border>

        <Border x:Name="CompletionPanel"
                Classes="autocompletePanel"
                IsVisible="False"
                Width="360"
                MaxHeight="280"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="96,72,0,0">
          <ListBox x:Name="CompletionList"
                   Classes="autocompleteList"
                   MaxHeight="266" />
        </Border>
      </Grid>

      <Border x:Name="TasksPanelResizeHandle"
              Grid.Column="1"
              Width="6"
              Background="Transparent"
              BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
              BorderThickness="1,0,0,1"
              ToolTip.Tip="Resize tasks panel" />

      <Border x:Name="TasksPanel"
              Grid.Column="2"
              Width="390"
              MinWidth="300"
              MaxWidth="620"
              BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
              BorderThickness="1,0,0,1"
              Background="{DynamicResource Notey.SurfaceLowBrush}">
        <Grid>
          <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="18,20,18,14">
              <TextBlock Grid.Column="0"
                         Classes="label"
                         Text="TASKS"
                         FontSize="16"
                         LetterSpacing="1.8"
                         VerticalAlignment="Center" />
              <Button x:Name="AddTaskButton"
                      Grid.Column="1"
                      Classes="command"
                      ToolTip.Tip="Add task"
                      AutomationProperties.Name="Add task">
                <PathIcon Classes="commandIcon" Data="M10.5,5 L13.5,5 L13.5,10.5 L19,10.5 L19,13.5 L13.5,13.5 L13.5,19 L10.5,19 L10.5,13.5 L5,13.5 L5,10.5 L10.5,10.5 Z" />
              </Button>
            </Grid>

            <Border x:Name="AddTaskPanel"
                    DockPanel.Dock="Top"
                    IsVisible="False"
                    Margin="18,0,18,12"
                    Padding="12"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource Notey.SurfaceBrushRaised}">
              <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,132,Auto" RowSpacing="8" ColumnSpacing="8">
                <TextBox x:Name="NewTaskTextBox"
                         Grid.Row="0"
                         Grid.Column="0"
                         Grid.ColumnSpan="3"
                         Classes="metadataInput"
                         PlaceholderText="New task" />
                <DatePicker x:Name="NewTaskDueDatePicker"
                            Grid.Row="1"
                            Grid.Column="1"
                            Classes="metadataInput"
                            DayFormat="dd"
                            MonthFormat="MM"
                            YearFormat="yyyy" />
                <Button x:Name="SaveNewTaskButton"
                        Grid.Row="1"
                        Grid.Column="2"
                        Content="Add"
                        Padding="12,6" />
              </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel x:Name="TaskSectionsPanel" Margin="18,0,18,20" Spacing="8" />
            </ScrollViewer>
          </DockPanel>

          <!-- Dim backdrop — blocks clicks on task rows while the edit card is open -->
          <Border x:Name="TaskEditBackdrop"
                  IsVisible="False"
                  Background="#A8000000"
                  ZIndex="10" />

          <!-- Task edit card — in-window overlay, not a Popup, so DatePicker cannot dismiss it -->
          <Border x:Name="TaskEditCard"
                  IsVisible="False"
                  ZIndex="11"
                  Margin="18"
                  VerticalAlignment="Center"
                  CornerRadius="10"
                  Padding="20,18"
                  BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
                  BorderThickness="1"
                  Background="{DynamicResource Notey.SurfaceBrush}"
                  BoxShadow="0 20 60 0 #D0000000">
            <StackPanel Spacing="14">
              <TextBlock Text="Edit task"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource Notey.PrimaryTextBrush}" />

              <StackPanel Spacing="6">
                <TextBlock Text="TASK" Classes="label" />
                <TextBox x:Name="TaskEditTextBox"
                         Classes="metadataInput"
                         PlaceholderText="Task text" />
              </StackPanel>

              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="DUE DATE" Classes="label" VerticalAlignment="Center" />
                  <Button x:Name="TaskEditClearDueDateButton"
                          Grid.Column="1"
                          Classes="panelAction"
                          Content="Clear"
                          Padding="10,4"
                          FontSize="11" />
                </Grid>
                <DatePicker x:Name="TaskEditDueDatePicker"
                            Classes="metadataInput"
                            DayFormat="dd"
                            MonthFormat="MM"
                            YearFormat="yyyy" />
              </StackPanel>

              <TextBlock x:Name="TaskEditErrorText"
                         Text="Task could not be saved. Remove metadata or invalid text and try again."
                         Foreground="{DynamicResource Notey.ErrorBrush}"
                         FontSize="12"
                         TextWrapping="Wrap"
                         IsVisible="False" />

              <Rectangle Height="1" Fill="{DynamicResource Notey.OutlineVariantBrush}" />

              <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                <Button x:Name="TaskEditDeleteButton"
                        Grid.Column="0"
                        Classes="panelDanger"
                        Content="Delete task" />
                <Button x:Name="TaskEditCancelButton"
                        Grid.Column="2"
                        Classes="panelAction"
                        Content="Cancel" />
                <Button x:Name="TaskEditSaveButton"
                        Grid.Column="3"
                        Classes="panelPrimary"
                        Content="Save" />
              </Grid>
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <Border x:Name="AssistantPanelResizeHandle"
            Grid.Row="3"
            Height="6"
            IsVisible="False"
            Background="Transparent"
            BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
            BorderThickness="0,1,0,0"
            ToolTip.Tip="Resize Notey Assistant panel" />

    <Border x:Name="AssistantPanel"
            Grid.Row="4"
            Height="220"
            MinHeight="140"
            MaxHeight="420"
            IsVisible="False"
            BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource Notey.SurfaceLowBrush}">
      <Grid RowDefinitions="Auto,*,Auto,Auto"
            RowSpacing="10"
            Margin="20,14">
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10">
          <TextBlock Grid.Column="0"
                     Classes="label"
                     Text="NOTEY ASSISTANT"
                     FontSize="16"
                     LetterSpacing="1.8"
                     VerticalAlignment="Center" />
          <TextBlock x:Name="AssistantStatusText"
                     Grid.Column="1"
                     Classes="label"
                     Text="Ready"
                     VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="1"
                CornerRadius="8"
                BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
                BorderThickness="1"
                Background="{DynamicResource Notey.SurfaceBrush}">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        Padding="12">
            <TextBlock x:Name="AssistantResponseText"
                       Text="Ask Notey Assistant to propose changes to the current note or tasks."
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Notey.SecondaryTextBrush}" />
          </ScrollViewer>
        </Border>

        <TextBox x:Name="AssistantPromptTextBox"
                 Grid.Row="2"
                 Classes="metadataInput"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="58"
                 MaxHeight="110"
                 PlaceholderText="Ask Notey Assistant..." />

        <Grid Grid.Row="3"
              ColumnDefinitions="*,Auto,Auto,Auto"
              ColumnSpacing="8">
          <TextBlock x:Name="AssistantErrorText"
                     Grid.Column="0"
                     Foreground="{DynamicResource Notey.ErrorBrush}"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center"
                     IsVisible="False" />
          <Button x:Name="AssistantCancelButton"
                  Grid.Column="1"
                  Classes="panelAction"
                  Content="Cancel"
                  IsEnabled="False" />
          <Button x:Name="AssistantApplyButton"
                  Grid.Column="2"
                  Classes="panelPrimary"
                  Content="Apply changes"
                  IsEnabled="False" />
          <Button x:Name="AssistantSendButton"
                  Grid.Column="3"
                  Classes="panelPrimary"
                  Content="Send" />
        </Grid>
      </Grid>
    </Border>

    <Border Grid.Row="5"
            BorderBrush="{DynamicResource Notey.OutlineVariantBrush}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource Notey.SurfaceLowestBrush}"
            Padding="14,0">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto"
            ColumnSpacing="16">
        <TextBlock Grid.Column="0" Classes="label" Text="CAPTURE DRAFT" VerticalAlignment="Center" Foreground="{DynamicResource Notey.SecondaryTextBrush}" />
        <TextBlock x:Name="AutosaveStatusText" Grid.Column="1" Classes="label" Text="CREATING DRAFT" VerticalAlignment="Center" />
        <TextBlock x:Name="WordCountText" Grid.Column="2" Classes="label" Text="WORDS 0" VerticalAlignment="Center" />
        <TextBlock x:Name="CurrentNotePathText"
                   Grid.Column="3"
                   Classes="label"
                   IsVisible="False"
                   Text=""
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center" />
        <Button x:Name="OpenInObsidianButton"
                Grid.Column="4"
                Content="Open in Obsidian"
                IsVisible="False"
                Padding="10,2"
                VerticalAlignment="Center" />
        <TextBlock Grid.Column="5" Classes="label" Text="UTF-8" VerticalAlignment="Center" />
        <TextBlock x:Name="CursorPositionText" Grid.Column="6" Classes="label" Text="LINE 1, COL 1" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Border x:Name="RecentDialogOverlay"
            Grid.RowSpan="6"
            Background="#01000000"
            IsVisible="False"
            ZIndex="100" />
  </Grid>
</Window>
